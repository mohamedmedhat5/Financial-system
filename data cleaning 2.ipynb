   "source": [
    "/"/"/"/n",
    "==================================================================/n",
    "موديل تعلم آلي للتنبؤ بإجمالي المصاريف الشهرية (Total_Expenses)/n",
    "==================================================================/n",
    "الفكرة الأساسية: نريد نظام تنبؤي /"استباقي/" — أي يتنبأ بالمصاريف/n",
    "المتوقعة في بداية الشهر اعتماداً على بيانات معروفة مسبقاً (الدخل،/n",
    "الشهر، المهرجانات...) وليس اعتماداً على بنود الصرف نفسها أو النسب/n",
    "المشتقة منها (لأن هذه بيانات /"بعد الحدث/" وتسبب Data Leakage)./n",
    "==================================================================/n",
    "/"/"/"/n",
    "/n",
    "import pandas as pd/n",
    "import numpy as np/n",
    "from sklearn.model_selection import train_test_split, GridSearchCV/n",
    "from sklearn.preprocessing import OneHotEncoder, RobustScaler/n",
    "from sklearn.compose import ColumnTransformer/n",
    "from sklearn.pipeline import Pipeline/n",
    "from sklearn.ensemble import GradientBoostingRegressor/n",
    "from sklearn.metrics import mean_absolute_error, r2_score/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# 1) تحميل البيانات/n",
    "# ------------------------------------------------------------------/n",
    "# مسار الملف على Kaggle/n",
    "df = pd.read_csv(r'datasets/raw/dataset 2/personal_expense_dataset.csv')/n",
    "/n",
    "print(/"شكل البيانات:/", df.shape)/n",
    "print(df.head())/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# 2) Feature Selection: استبعاد أعمدة الـ Leakage/n",
    "# ------------------------------------------------------------------/n",
    "# السبب: أي عمود مشتق من بنود الصرف (Food, Rent, Bills, ...) أو من/n",
    "# النسب (Food_Ratio, Rent_Ratio, ...) أو Savings هو في الحقيقة نتيجة/n",
    "# لعملية الصرف نفسها (Total_Expenses = مجموع هذه البنود، والنسب =/n",
    "# البند / الإجمالي). فلو تركناها في X فإن الموديل سيتعلم /"يحسب/"/n",
    "# الإجمالي بدل أن /"يتنبأ/" به، وهذا يعطي دقة عالية جداً في الاختبار/n",
    "# لكنه عديم الفائدة عملياً لأن هذه البيانات غير متاحة في بداية الشهر./n",
    "/n",
    "leakage_cols = [/n",
    "    /"Food/", /"Groceries/", /"Transport/", /"Entertainment/", /"Shopping/",/n",
    "    /"Rent/", /"Bills/", /"Healthcare/", /"Education/",   # بنود الصرف التفصيلية/n",
    "    /"Food_Ratio/", /"Groceries_Ratio/", /"Transport_Ratio/",/n",
    "    /"Entertainment_Ratio/", /"Shopping_Ratio/", /"Rent_Ratio/",/n",
    "    /"Bills_Ratio/", /"Healthcare_Ratio/", /"Education_Ratio/",  # النسب/n",
    "    /"Savings/",  # المدخرات (نتيجة أيضاً: Income - Total_Expenses)/n",
    "]/n",
    "/n",
    "target_col = /"Total_Expenses/"/n",
    "/n",
    "# الأعمدة المتبقية بعد الاستبعاد هي فقط العوامل /"السابقة/" لعملية الصرف/n",
    "feature_cols = [c for c in df.columns if c not in leakage_cols + [target_col, /"UserID/"]]/n",
    "/n",
    "X = df[feature_cols].copy()/n",
    "y = df[target_col].copy()/n",
    "/n",
    "print(/"/nالأعمدة المستخدمة كمدخلات (Features):/")/n",
    "print(feature_cols)/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# 3) تحديد الأعمدة الرقمية والفئوية لتطبيق المعالجة المناسبة لكل نوع/n",
    "# ------------------------------------------------------------------/n",
    "categorical_cols = [/"Festivals/"]  # يحتاج One-Hot Encoding/n",
    "numerical_cols = [c for c in feature_cols if c not in categorical_cols]/n",
    "# مثال: Year, Month, Income, Income_Bracket, Festival_Count/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# 4) بناء Preprocessing Pipeline: Encoding + Scaling/n",
    "# ------------------------------------------------------------------/n",
    "# - OneHotEncoder لعمود Festivals: لأنه عمود نصي (فئوي) غير مرتب،/n",
    "#   ولا يجوز تحويله لأرقام عادية لأن ذلك يوهم الموديل بوجود ترتيب/n",
    "#   بين المهرجانات وهو غير صحيح./n",
    "# - RobustScaler للأعمدة الرقمية: لأنه يعتمد على الوسيط (Median)/n",
    "#   والمدى الربيعي (IQR) بدل المتوسط والانحراف المعياري، وهذا يجعله/n",
    "#   أقل تأثراً بالـ Outliers الموجودة في الدخل والمصاريف مقارنة/n",
    "#   بـ StandardScaler العادي./n",
    "/n",
    "preprocessor = ColumnTransformer(/n",
    "    transformers=[/n",
    "        (/"num/", RobustScaler(), numerical_cols),/n",
    "        (/"cat/", OneHotEncoder(handle_unknown=/"ignore/", sparse_output=False), categorical_cols),/n",
    "    ]/n",
    ")/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# 5) تقسيم البيانات إلى Train / Test (80% / 20%)/n",
    "# ------------------------------------------------------------------/n",
    "# نستخدم random_state ثابت لضمان إمكانية إعادة إنتاج نفس النتائج/n",
    "# عند إعادة تشغيل الكود (Reproducibility)./n",
    "X_train, X_test, y_train, y_test = train_test_split(/n",
    "    X, y, test_size=0.20, random_state=42/n",
    ")/n",
    "/n",
    "print(f/"/nحجم بيانات التدريب: {X_train.shape[0]} صف/")/n",
    "print(f/"حجم بيانات الاختبار: {X_test.shape[0]} صف/")/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# 6) بناء الموديل: GradientBoostingRegressor داخل Pipeline كامل/n",
    "# ------------------------------------------------------------------/n",
    "# دمج المعالجة المسبقة (preprocessor) مع الموديل في Pipeline واحد/n",
    "# يضمن عدم تسرب معلومات من بيانات الاختبار أثناء التدريب (Data/n",
    "# Leakage من نوع آخر يخص الـ Scaling نفسه)، لأن fit تتم فقط على/n",
    "# بيانات التدريب ثم transform على الاختبار./n",
    "/n",
    "model_pipeline = Pipeline(steps=[/n",
    "    (/"preprocessor/", preprocessor),/n",
    "    (/"regressor/", GradientBoostingRegressor(random_state=42))/n",
    "])/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# 7) ضبط المعايير (Hyperparameter Tuning) باستخدام GridSearchCV/n",
    "# ------------------------------------------------------------------/n",
    "# الهدف من ضبط هذه المعايير تحديداً هو منع الـ Overfitting:/n",
    "# - n_estimators: عدد الأشجار (كثرتها بدون ضبط باقي المعايير تسبب حفظ للبيانات)/n",
    "# - learning_rate: معدل تعلم منخفض مع عدد أشجار أكبر = تعميم أفضل/n",
    "# - max_depth: أشجار ضحلة (3-5) تمنع الموديل من حفظ تفاصيل دقيقة جداً/n",
    "# - subsample: أخذ عينة عشوائية من بيانات التدريب لكل شجرة (Stochastic/n",
    "#   Gradient Boosting) يقلل التباين ويحسن التعميم/n",
    "# - min_samples_leaf: يمنع إنشاء أوراق (leaves) تحتوي على عدد قليل/n",
    "#   جداً من العينات، وهو ما قد يمثل حفظاً لحالات فردية (Noise)/n",
    "/n",
    "param_grid = {/n",
    "    /"regressor__n_estimators/": [100, 200, 300],/n",
    "    /"regressor__learning_rate/": [0.01, 0.05, 0.1],/n",
    "    /"regressor__max_depth/": [3, 4, 5],/n",
    "    /"regressor__subsample/": [0.8, 1.0],/n",
    "    /"regressor__min_samples_leaf/": [5, 10, 20],/n",
    "}/n",
    "/n",
    "grid_search = GridSearchCV(/n",
    "    estimator=model_pipeline,/n",
    "    param_grid=param_grid,/n",
    "    cv=5,                      # 5-Fold Cross Validation لتقييم أكثر ثباتاً/n",
    "    scoring=/"neg_mean_absolute_error/",/n",
    "    n_jobs=-1,/n",
    "    verbose=1,/n",
    ")/n",
    "/n",
    "grid_search.fit(X_train, y_train)/n",
    "/n",
    "print(/"/nأفضل معايير (Hyperparameters):/")/n",
    "print(grid_search.best_params_)/n",
    "/n",
    "best_model = grid_search.best_estimator_/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# 8) التقييم: MAE و R2 Score على بيانات التدريب والاختبار/n",
    "# ------------------------------------------------------------------/n",
    "# نقارن أداء الموديل على Train و Test معاً:/n",
    "# - إذا كان الأداء ممتازاً على Train وضعيفاً جداً على Test => Overfitting/n",
    "# - MAE يعطينا فكرة واقعية عن متوسط الخطأ بالجنيه/الدولار (سهل الفهم)/n",
    "# - R2 Score يعطينا فكرة عن نسبة التباين في المصاريف التي يفسرها الموديل/n",
    "/n",
    "y_train_pred = best_model.predict(X_train)/n",
    "y_test_pred = best_model.predict(X_test)/n",
    "/n",
    "train_mae = mean_absolute_error(y_train, y_train_pred)/n",
    "test_mae = mean_absolute_error(y_test, y_test_pred)/n",
    "/n",
    "train_r2 = r2_score(y_train, y_train_pred)/n",
    "test_r2 = r2_score(y_test, y_test_pred)/n",
    "/n",
    "print(/"/n================ نتائج التقييم ================/")/n",
    "print(f/"Train MAE : {train_mae:.2f}/")/n",
    "print(f/"Test  MAE : {test_mae:.2f}/")/n",
    "print(f/"Train R2  : {train_r2:.4f}/")/n",
    "print(f/"Test  R2  : {test_r2:.4f}/")/n",
    "print(/"=================================================/")/n",
    "/n",
    "# ملاحظة: فرق كبير بين Train و Test (مثلاً R2 تدريب 0.98 مقابل/n",
    "# R2 اختبار 0.60) يعني أن الموديل ما زال يحفظ البيانات، وهنا يجب/n",
    "# تقليل max_depth أو زيادة min_samples_leaf أو تقليل learning_rate./n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# 9) (اختياري) أهمية المتغيرات Feature Importance/n",
    "# ------------------------------------------------------------------/n",
    "# يساعد على فهم أي العوامل (الدخل، الشهر، المهرجانات...) لها التأثير/n",
    "# الأكبر على توقع المصاريف، وهذا مفيد لتفسير الموديل للمستخدم النهائي./n",
    "/n",
    "feature_names = (/n",
    "    numerical_cols +/n",
    "    list(best_model.named_steps[/"preprocessor/"]/n",
    "         .named_transformers_[/"cat/"]/n",
    "         .get_feature_names_out(categorical_cols))/n",
    ")/n",
    "/n",
    "importances = best_model.named_steps[/"regressor/"].feature_importances_/n",
    "/n",
    "importance_df = pd.DataFrame({/n",
    "    /"Feature/": feature_names,/n",
    "    /"Importance/": importances/n",
    "}).sort_values(/"Importance/", ascending=False)/n",
    "/n",
    "print(/"/nأهمية المتغيرات (Feature Importance):/")/n",
    "print(importance_df.to_string(index=False))"
   ]
  },
