    "/"/"/"/n",
    "==================================================================/n",
    "تحسينات إضافية مقترحة على الموديل الأساسي/n",
    "==================================================================/n",
    "/"/"/"/n",
    "/n",
    "import numpy as np/n",
    "import pandas as pd/n",
    "from sklearn.linear_model import LinearRegression/n",
    "from sklearn.model_selection import cross_val_score/n",
    "/n",
    "# افترض أن best_model, X_train, X_test, y_train, y_test, preprocessor/n",
    "# موجودين بالفعل من الكود السابق/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# تحسين 1: MAPE بدل الاعتماد على MAE وحده/n",
    "# ------------------------------------------------------------------/n",
    "# MAE = 261 قد يبدو كبير أو صغير حسب حجم الأرقام نفسها. الأفضل نعرف/n",
    "# نسبة الخطأ من متوسط قيمة Total_Expenses لفهم الحجم الحقيقي للخطأ./n",
    "/n",
    "y_test_pred = best_model.predict(X_test)/n",
    "mape = np.mean(np.abs((y_test - y_test_pred) / y_test)) * 100/n",
    "mean_expense = y_test.mean()/n",
    "/n",
    "print(f/"متوسط Total_Expenses في بيانات الاختبار: {mean_expense:.2f}/")/n",
    "print(f/"MAPE (نسبة الخطأ المئوية): {mape:.2f}%/")/n",
    "print(f/"MAE كنسبة من المتوسط: {(261.60/mean_expense)*100:.2f}%/")/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# تحسين 2: مقارنة بموديل بسيط (Linear Regression) كـ Baseline/n",
    "# ------------------------------------------------------------------/n",
    "# لو موديل خطي بسيط بيدّي نفس النتيجة تقريباً، فده معناه إن العلاقة/n",
    "# شبه خطية (Income وحده كافي)، وإن GradientBoosting مش بيضيف قيمة/n",
    "# حقيقية غير التعقيد الزائد. لو الفرق كبير لصالح GBM، يبقى فيه علاقات/n",
    "# غير خطية فعلاً استفاد منها الموديل./n",
    "/n",
    "from sklearn.pipeline import Pipeline/n",
    "linear_pipeline = Pipeline(steps=[/n",
    "    (/"preprocessor/", preprocessor),/n",
    "    (/"regressor/", LinearRegression())/n",
    "])/n",
    "linear_pipeline.fit(X_train, y_train)/n",
    "lr_pred = linear_pipeline.predict(X_test)/n",
    "/n",
    "from sklearn.metrics import mean_absolute_error, r2_score/n",
    "print(f/"/nLinear Regression - Test MAE: {mean_absolute_error(y_test, lr_pred):.2f}/")/n",
    "print(f/"Linear Regression - Test R2 : {r2_score(y_test, lr_pred):.4f}/")/n",
    "print(/"(قارن هذا بنتائج GradientBoosting: MAE=261.60, R2=0.9858)/")/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# تحسين 3: Cross-Validation على كامل بيانات التدريب (وليس Split واحد)/n",
    "# ------------------------------------------------------------------/n",
    "# تقييم أكثر ثباتاً بدل الاعتماد على تقسيم واحد فقط للـ Test/n",
    "/n",
    "cv_scores = cross_val_score(/n",
    "    best_model, X_train, y_train, cv=5, scoring=/"neg_mean_absolute_error/"/n",
    ")/n",
    "print(f/"/nMAE عبر 5-Fold CV: {-cv_scores.mean():.2f} (+/- {cv_scores.std():.2f})/")/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# تحسين 4: تحليل الأخطاء الأكبر (Residual Analysis)/n",
    "# ------------------------------------------------------------------/n",
    "# نشوف هل الموديل بيخطئ أكتر عند دخل معين أو شهر معين، وده ممكن/n",
    "# يوجّهنا لإضافة Feature Engineering (مثلاً Income * Festival_Count)/n",
    "/n",
    "residuals = y_test - y_test_pred/n",
    "error_df = X_test.copy()/n",
    "error_df[/"Actual/"] = y_test.values/n",
    "error_df[/"Predicted/"] = y_test_pred/n",
    "error_df[/"Abs_Error/"] = np.abs(residuals.values)/n",
    "/n",
    "print(/"/nأكبر 10 حالات خطأ (يستحق مراجعتها):/")/n",
    "print(error_df.sort_values(/"Abs_Error/", ascending=False).head(10)/n",
    "      [[/"Income/", /"Month/", /"Festivals/", /"Actual/", /"Predicted/", /"Abs_Error/"]])/n",
    "/n",
    "# ------------------------------------------------------------------/n",
    "# تحسين 5 (اختياري): Feature Engineering - تفاعل بين الدخل والشهر/المهرجان/n",
    "# ------------------------------------------------------------------/n",
    "# ممكن تضيف عمود جديد قبل التدريب:/n",
    "# X[/"Income_x_FestivalCount/"] = X[/"Income/"] * X[/"Festival_Count/"]/n",
    "# ده ممكن يساعد الموديل يلتقط إن تأثير المهرجانات بيكبر مع زيادة الدخل"
   ]
