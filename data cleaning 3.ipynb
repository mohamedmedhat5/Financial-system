        "    if x < 0.8:/n",
        "        return /"Poor/"/n",
        "    elif x < 1:/n",
        "        return /"Average/"/n",
        "    else:/n",
        "        return /"Good/"/n",
        "/n",
        "df[/"Affordability_Level/"] = df[/"Income_to_Cost_Ratio/"].apply(classify_ratio)"
      ]
